# Homelab runtime secrets for `docker compose up`.
# Copy to `secrets.env` next to docker-compose.yml, then `chmod 600 secrets.env`.
# NEVER commit the real file — .gitignore already excludes it.

# Cloudflare Tunnel token issued in Zero Trust > Networks > Tunnels > <tunnel> > Connectors.
# cloudflared picks this up automatically (no CLI flag needed).
TUNNEL_TOKEN=

# FastAPI runtime env (optional; extend as settings grow).
APP_ENV=production
LOG_LEVEL=INFO
