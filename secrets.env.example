# Homelab runtime secrets for `docker compose up`.
# Copy to `secrets.env` next to docker-compose.yml, then `chmod 600 secrets.env`.
# NEVER commit the real file — .gitignore already excludes it.

# Cloudflare Tunnel token issued in Zero Trust > Networks > Tunnels > <tunnel> > Connectors.
# cloudflared picks this up automatically (no CLI flag needed).
TUNNEL_TOKEN=

# FastAPI runtime env.
APP_ENV=production
LOG_LEVEL=INFO

# HMAC secret for click-tracking URL signatures (/r/{article_id}?s=...).
# Generate with: openssl rand -hex 32
# MUST be the same value that daily_news.py runs with in GitHub Actions — otherwise
# signatures won't verify and every link silently falls back to the unsigned URL.
# Rotating this invalidates every in-flight email link, so rotate rarely.
CLICK_SIGNING_SECRET=

# Public hostname the email links point at (no trailing slash).
PUBLIC_BASE_URL=https://newspaper.example.com

# Salt for SHA-256(ip || salt). Rotate periodically to break long-term tracking.
# Generate with: openssl rand -hex 16
IP_SALT=

# Neon connection string (same DATABASE_URL the daily batch uses).
DATABASE_URL=

# Where /r/{id} redirects when article_id is unknown. Replace once Astro lands.
MISSING_REDIRECT_URL=https://newspaper.example.com/missing
